# ── 앱 기본 설정 ──────────────────────────────────────────────────
APP_NAME="오마하부자 API"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# ── CORS (쉼표 구분) ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── KIS (한국투자증권) API ────────────────────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                    # 예: 12345678-01
KIS_IS_VIRTUAL=true                # true=모의투자, false=실전투자

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (Claude) — OpenAI 대안 ─────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── DART (금융감독원 전자공시) ────────────────────────────────────
# https://opendart.fss.or.kr 에서 발급 (무료)
DART_API_KEY=

# ── Supabase (Stage 2: DB + 인증) ────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis (캐시, 선택사항) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── 가치분석 파라미터 (기본값 사용 시 설정 불필요) ─────────────────
DCF_DISCOUNT_RATE=0.10             # 할인율 (기본 10%)
DCF_GROWTH_YEARS=10                # 성장기간 (기본 10년)
DCF_TERMINAL_GROWTH=0.03           # 영구성장률 (기본 3%)

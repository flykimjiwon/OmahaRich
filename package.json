{
  "name": "omaha-investor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,yellow \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "turbo run dev --filter=@omaha/web",
    "dev:api": "cd backend && .venv/bin/uvicorn app.main:app --reload --port 8101",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
